{
  "manifest_version": 3,
  "name": "CopyBox Lite",
  "description": "一键复制和保存常用内容的浏览器扩展",
  "version": "1.0.0",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "copybox16.png",
      "48": "copybox48.png",
      "128": "copybox128.png"
    }
  },
  "icons": {
    "16": "copybox16.png",
    "48": "copybox48.png",
    "128": "copybox128.png"
  }
}
